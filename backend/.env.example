# PostgreSQL state DB (хранит конфиги source/target/kafka/connect)
STATE_DB_DSN=postgresql://postgres:postgres@localhost:5432/migration_state

# Flask
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=true

# Optional: require X-Config-Token for /api/config reads/writes/tests.
# Leave empty for local development without config API protection.
CONFIG_API_TOKEN=

# Set to false only for emergency fallback to the old idempotent bootstrap.
STATE_DB_USE_ALEMBIC=true
