# ── State DB (PostgreSQL) ─────────────────────────────────────────────────────
# Workers connect directly to the state DB — no HTTP to Flask.
STATE_DB_DSN=postgresql://postgres:postgres@localhost:5432/migration_state

# Unique identifier for this worker process.
# Default: hostname:pid  (auto-generated, leave unset for most cases)
# WORKER_ID=my-worker-1

# ── Bulk loading ──────────────────────────────────────────────────────────────
# Number of rows inserted per batch (higher = fewer round-trips, more memory)
BULK_BATCH_SIZE=5000

# Seconds to wait between chunk claim polls when no work is available
BULK_POLL_INTERVAL=5

# ── CDC apply ─────────────────────────────────────────────────────────────────
# Kafka records consumed per poll cycle
CDC_BATCH_SIZE=500

# Seconds between heartbeat/lag checkin writes to state DB
CDC_CHECKIN_SEC=30

# Kafka consumer poll timeout (ms)
CDC_POLL_MS=1000

# Consecutive Kafka poll errors before CDC migration is marked FAILED
CDC_POLL_ERROR_THRESHOLD=3

# Seconds between scans for new CDC migrations needing a worker
CDC_SCAN_INTERVAL=3

# Seconds between process-level worker heartbeat writes
WORKER_HEARTBEAT_SEC=10
