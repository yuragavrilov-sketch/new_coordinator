# ── Flask backend ─────────────────────────────────────────────────────────────
# URL of the running Flask backend
API_URL=http://localhost:5000

# Unique identifier for this worker process.
# Default: hostname:pid  (auto-generated, usually fine to leave unset)
# WORKER_ID=my-worker-1

# ── Bulk loading ──────────────────────────────────────────────────────────────
# Number of rows inserted per batch (higher = fewer round-trips, more memory)
BULK_BATCH_SIZE=5000

# Seconds to wait between chunk claim polls when no work is available
BULK_POLL_INTERVAL=5

# ── CDC apply ─────────────────────────────────────────────────────────────────
# Kafka records consumed per poll cycle
CDC_BATCH_SIZE=500

# Seconds between heartbeat/lag checkin calls to the backend
CDC_CHECKIN_SEC=30

# Kafka consumer poll timeout (ms)
CDC_POLL_MS=1000

# Seconds between scans for new CDC migrations needing a worker
CDC_SCAN_INTERVAL=15
